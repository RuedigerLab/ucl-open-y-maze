{
  "$defs": {
    "DoorCommand": {
      "properties": {
        "doorId": {
          "title": "DoorId",
          "type": "integer"
        },
        "probability": {
          "default": 0,
          "maximum": 1,
          "minimum": 0,
          "title": "Probability",
          "type": "number"
        }
      },
      "required": [
        "doorId"
      ],
      "title": "DoorCommand",
      "type": "object"
    },
    "ExperimentSession": {
      "description": "The base class for creating ucl-open experiment models.",
      "properties": {
        "workflow": {
          "description": "Path to the workflow running the experiment.",
          "title": "Workflow",
          "type": "string"
        },
        "commit": {
          "description": "Commit hash of the experiment repo.",
          "title": "Commit",
          "type": "string"
        },
        "repositoryUrl": {
          "description": "The URL of the git repository used to version experiment source code.",
          "title": "RepositoryUrl",
          "type": "string"
        },
        "subjectId": {
          "description": "The subject id for this session.",
          "title": "SubjectId",
          "type": "string"
        },
        "sessionId": {
          "description": "The session identifier.",
          "title": "SessionId",
          "type": "string"
        }
      },
      "required": [
        "workflow",
        "commit",
        "repositoryUrl",
        "subjectId",
        "sessionId"
      ],
      "title": "ExperimentSession",
      "type": "object"
    },
    "RegionTrigger": {
      "properties": {
        "threshold": {
          "maximum": 255,
          "minimum": 0,
          "title": "Threshold",
          "type": "integer"
        },
        "sumThreshold": {
          "minimum": 0,
          "title": "SumThreshold",
          "type": "integer"
        },
        "regionPolygon": {
          "items": {
            "$ref": "#/$defs/Vector2"
          },
          "title": "RegionPolygon",
          "type": "array"
        }
      },
      "required": [
        "threshold",
        "sumThreshold",
        "regionPolygon"
      ],
      "title": "RegionTrigger",
      "type": "object"
    },
    "RewardProbability": {
      "properties": {
        "rewardId": {
          "title": "RewardId",
          "type": "integer"
        },
        "probability": {
          "default": 0,
          "maximum": 1,
          "minimum": 0,
          "title": "Probability",
          "type": "number"
        }
      },
      "required": [
        "rewardId"
      ],
      "title": "RewardProbability",
      "type": "object"
    },
    "UclOpenYMazeRig": {
      "properties": {
        "rootPath": {
          "description": "The root path on which to log all data.",
          "title": "RootPath",
          "type": "string"
        },
        "version": {
          "const": "0.0.0-rc1",
          "default": "0.0.0-rc1",
          "title": "Version",
          "type": "string"
        }
      },
      "required": [
        "rootPath"
      ],
      "title": "UclOpenYMazeRig",
      "type": "object"
    },
    "UclOpenYMazeTaskLogic": {
      "properties": {
        "version": {
          "const": "0.0.0-rc1",
          "default": "0.0.0-rc1",
          "title": "Version",
          "type": "string"
        },
        "name": {
          "const": "UclOpenYMaze",
          "default": "UclOpenYMaze",
          "description": "Name of the task logic",
          "title": "Name",
          "type": "string"
        },
        "taskParameters": {
          "$ref": "#/$defs/UclOpenYMazeTaskParameters",
          "description": "Parameters of the task logic",
          "title": "TaskParameters"
        }
      },
      "required": [
        "taskParameters"
      ],
      "title": "UclOpenYMazeTaskLogic",
      "type": "object"
    },
    "UclOpenYMazeTaskParameters": {
      "properties": {
        "rngSeed": {
          "default": null,
          "description": "Seed of the random number generator",
          "title": "RngSeed",
          "type": [
            "number",
            "null"
          ]
        },
        "regionTriggers": {
          "additionalProperties": {
            "$ref": "#/$defs/RegionTrigger"
          },
          "title": "RegionTriggers",
          "type": "object"
        },
        "armRewardProbabilities": {
          "additionalProperties": {
            "$ref": "#/$defs/RewardProbability"
          },
          "title": "ArmRewardProbabilities",
          "type": "object"
        },
        "triggerDoorMapping": {
          "additionalProperties": {
            "items": {
              "$ref": "#/$defs/DoorCommand"
            },
            "type": "array"
          },
          "title": "TriggerDoorMapping",
          "type": "object"
        },
        "triggerVisualMapping": {
          "additionalProperties": {
            "$ref": "#/$defs/VisualStimulation"
          },
          "title": "TriggerVisualMapping",
          "type": "object"
        }
      },
      "required": [
        "regionTriggers",
        "armRewardProbabilities",
        "triggerDoorMapping",
        "triggerVisualMapping"
      ],
      "title": "UclOpenYMazeTaskParameters",
      "type": "object"
    },
    "Vector2": {
      "properties": {
        "x": {
          "description": "X coordinate of the point.",
          "title": "X",
          "type": "number"
        },
        "y": {
          "description": "Y coordinate of the point.",
          "title": "Y",
          "type": "number"
        }
      },
      "required": [
        "x",
        "y"
      ],
      "title": "Vector2",
      "type": "object"
    },
    "VisualStimulation": {
      "properties": {
        "screenId": {
          "title": "ScreenId",
          "type": "integer"
        }
      },
      "required": [
        "screenId"
      ],
      "title": "VisualStimulation",
      "type": "object"
    }
  },
  "anyOf": [
    {
      "$ref": "#/$defs/UclOpenYMazeTaskLogic"
    },
    {
      "$ref": "#/$defs/UclOpenYMazeRig"
    },
    {
      "$ref": "#/$defs/ExperimentSession"
    }
  ],
  "title": "RootModel[Union[UclOpenYMazeTaskLogic, UclOpenYMazeRig, ExperimentSession]]"
}